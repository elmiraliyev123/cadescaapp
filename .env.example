# Server-only. Do not prefix these with NEXT_PUBLIC_.
RESEND_API_KEY=
EMAIL_FROM="Cadesca <verify@cadesca.com>"
AUTH_SECRET=
DATABASE_URL=
DATABASE_POOL_MAX=5
DATABASE_IDLE_TIMEOUT_MS=10000
DATABASE_CONNECTION_TIMEOUT_MS=5000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Backward-compatible legacy key name also supported:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Backward-compatible alias supported for the current Vercel project:
service_role=
TURNSTILE_SECRET_KEY=
GEMINI_API_KEY=
GEMINI_OCR_MODEL=gemini-3.5-flash
ENABLE_STUDENT_ID_OCR=false

# Optional server-side image moderation for profile photos and social post images.
# Use either a custom Cloudflare Worker endpoint or direct Workers AI REST credentials.
CLOUDFLARE_IMAGE_MODERATION_URL=
CLOUDFLARE_IMAGE_MODERATION_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGE_MODERATION_MODEL=@cf/meta/llama-3.2-11b-vision-instruct
CLOUDFLARE_IMAGE_MODERATION_REQUIRED=false

# Public browser-visible URLs.
NEXT_PUBLIC_SITE_ORIGIN=https://cadesca.com
NEXT_PUBLIC_AUTH_ORIGIN=https://auth.cadesca.com
NEXT_PUBLIC_APP_ORIGIN=https://app.cadesca.com
NEXT_PUBLIC_COOKIE_DOMAIN=.cadesca.com
NEXT_PUBLIC_APP_URL=https://app.cadesca.com
NEXT_PUBLIC_MERCHANT_URL=https://merchant.cadesca.com
NEXT_PUBLIC_ADMIN_URL=https://adminlog.cadesca.com
NEXT_PUBLIC_API_URL=https://api.cadesca.com
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

CADESCA_ADMIN_EMAIL=
CADESCA_ADMIN_PASSWORD=
# CADESCA_ADMIN_EMAILS=admin@example.com,ops@example.com

# Optional server-side admin access restrictions.
# Exact IPv4/IPv6 entries only. CIDR ranges are not supported in this version.
ADMIN_ALLOWED_IPS=
ADMIN_CF_ACCESS_REQUIRED=false
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
# Backward-compatible aliases also supported:
ADMIN_CF_ACCESS_TEAM_DOMAIN=
ADMIN_CF_ACCESS_AUD=

# Wallet pass generation.
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLASS_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_WALLET_ISSUER_NAME=Cadesca
GOOGLE_WALLET_ORIGINS=https://app.cadesca.com
GOOGLE_WALLET_LOGO_URL=https://app.cadesca.com/cadesca-mark.png
GOOGLE_WALLET_HERO_IMAGE_URL=https://app.cadesca.com/cadesca-logo.png
GOOGLE_WALLET_DEFAULT_EXPIRY_DAYS=365
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_CERT=
APPLE_WALLET_KEY=
APPLE_WALLET_KEY_PASSWORD=
APPLE_WALLET_WWDR=

# Optional diagnostics. Keep false in production unless debugging a deploy.
DEBUG_ENV_STATUS=false
# Optional Search Console verification token rendered as a Google verification meta tag.
GOOGLE_SITE_VERIFICATION=

# Comma-separated, verified official Cadesca Instagram, TikTok, or LinkedIn URLs.
# Leave unset until the official accounts are confirmed.
CADESCA_OFFICIAL_SOCIAL_URLS=
